        @endif

        <!-- Error Alert -->
        @if ($errors->any())
            <div class="p-4 bg-red-50 border border-red-200 rounded-lg mb-6">
                <ul class="list-none">
                    @foreach ($errors->all() as $error)
                        <li class="text-sm text-red-600">{{ $error }}</li>
                    @endforeach
                </ul>
            </div>
